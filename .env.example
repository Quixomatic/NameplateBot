# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Application ID (Client ID) from the Discord developer portal
CLIENT_ID=your-client-id-here

# Name of the role to assign after verification (created automatically if missing)
VERIFIED_ROLE_NAME=Verified

# How often to remind unverified members (in hours)
REMINDER_INTERVAL_HOURS=24

# How many reminders to send before giving up (0 = unlimited)
MAX_REMINDERS=3
